PORT=8080
DATABASE_URL=postgres://user:pass@host:5432/stooping

# App -> server auth. This is MVP auth and is public in the Expo bundle.
APP_API_KEY=change-me-shared-secret

# Staff-only routes. Do not ship this in the Expo customer app.
STAFF_API_KEY=change-me-staff-secret

# Used for confirm links and Twilio webhook URLs.
PUBLIC_URL=https://api.stoopingclub.example

# Shopify Admin API, server-only. Never put this token in Expo env vars.
SHOPIFY_STORE_DOMAIN=stooping-club-berkeley.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2026-04
SHOPIFY_LOCATION_ID=gid://shopify/Location/123456789

# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM=+15105550100

# Policy
TIMEZONE=America/Los_Angeles
RELIST_GRACE_HOURS=19
