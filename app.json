{
  "expo": {
    "name": "Stooping Club",
    "slug": "stooping-club-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stoopingclub",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.berkeleystooping.mobile"
    },
    "android": {
      "package": "org.berkeleystooping.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications"
    ]
  }
}
